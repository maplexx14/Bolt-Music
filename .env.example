# Database Variables
DB_USER=music_user
DB_PASSWORD=music_secure_password
DB_NAME=music_db

# Backend Variables
# To generate a new SECRET_KEY run `openssl rand -hex 32`
SECRET_KEY=change-this-to-a-secure-random-string
# API URL that frontend contacts - since both are hosted on same domain it will be proxied
VITE_API_URL=/api
# CDN URL for serving music and cover files (e.g. https://cdn.yourdomain.com)
# If set, all audio and cover files will be loaded from this CDN instead of the origin server.
# Leave empty or omit to serve files from the origin server (default).
# VITE_CDN_URL=https://cdn.yourdomain.com
